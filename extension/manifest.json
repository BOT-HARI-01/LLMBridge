{
  "manifest_version": 3,
  "name": "LLM Bridge",
  "version": "1.1",
  "permissions": ["nativeMessaging", "scripting", "tabs"],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://gemini.google.com/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://gemini.google.com/*"
      ],
      "js": ["content.js"]
    }
  ]
}